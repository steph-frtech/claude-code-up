[15.196854, "o", "\u001b[90m‚Ēā\u001b[39m\r\n\u001b[32m‚óá\u001b[39m  \u001b[0mPlan\u001b[0m \u001b[90m‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ēģ\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m\u001b[22m                                                                                          \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m\u001b[1mProject\u001b[22m\u001b[2m    first-app-test\u001b[22m                                                                 \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m\u001b[1mLocation\u001b[22m\u001b[2m   /data/dev/first-app-test\u001b[22m                                                       \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m\u001b[1mCategory\u001b[22m\u001b[2m   mobile\u001b[22m                                                                         \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m\u001b[1mLanguage\u001b[22m\u001b[2m   ts\u001b[22m                                                                             \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m\u001b[1mFramework\u001b[22m\u001b[2m  expo\u001b[22m                                                                           \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m\u001b[1mDatabase\u001b[22m\u001b[2m   none\u001b[22m                                                                           \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m\u001b[1mScaffold\u001b[22m\u001b[2m   \u001b[36mnpx -y create-expo-app@latest {{name}}\u001b[39m\u001b[2m [template: default]\u001b[22m\u001b[2m\u001b[22m                     \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m\u001b[22m                                                                                          \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m\u001b[1mWill create:\u001b[22m\u001b[2m\u001b[22m                                                                              \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[2m‚ÄĘ\u001b[22m\u001b[2m .claude/settings.json\u001b[22m                                                                 \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[2m‚ÄĘ\u001b[22m\u001b[2m .claude/skills/    \u001b[2m(empty ‚ÄĒ registry coming in v0.2)\u001b[22m\u001b[2m\u001b[22m                                  \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[2m‚ÄĘ\u001b[22m\u001b[2m .claude/agents/    \u001b[2m(empty)\u001b[22m\u001b[2m\u001b[22m                                                            \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[2m‚ÄĘ\u001b[22m\u001b[2m CLAUDE.md\u001b[22m                                                                             \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[2m‚ÄĘ\u001b[22m\u001b[2m .gitignore\u001b[22m                                                                            \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[2m‚ÄĘ\u001b[22m\u001b[2m git init\u001b[22m                                                                              \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m\u001b[22m                                                                                          \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m\u001b[1mGitHub:\u001b[22m\u001b[2m\u001b[22m                                                                                   \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[2m‚ÄĘ\u001b[22m\u001b[2m steph-frtech/first-app-test \u001b[2m(private)\u001b[22m\u001b[2m \u001b[2m[\u001b[32mcreate new\u001b[39m]\u001b[22m\u001b[2m\u001b[22m                                    \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[2m‚ÄĘ\u001b[22m\u001b[2m Press enter to skip\u001b[22m                                                                   \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[2m‚ÄĘ\u001b[22m\u001b[2m repo already created ‚ÄĒ will push initial commit at the end\u001b[22m                            \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m\u001b[22m                                                                                          \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m\u001b[1mClaude stack:\u001b[22m\u001b[2m\u001b[22m                                                                             \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[32m‚óŹ\u001b[39m Karpathy CLAUDE.md guidelines \u001b[2m[\u001b[32mproject\u001b[39m]\u001b[22m\u001b[2m\u001b[22m                                               \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[33m‚óź\u001b[39m Superpowers (TDD, debugging, brainstorming) \u001b[2m[\u001b[32mproject\u001b[39m]\u001b[22m\u001b[2m\u001b[33m  (7/14 skills)\u001b[39m\u001b[22m                  \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[32m‚óŹ\u001b[39m claude-mem (persistent memory across sessions) \u001b[2m[\u001b[33muser-doc\u001b[39m]\u001b[22m\u001b[2m\u001b[22m   "]
[15.196891, "o", "                          \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[32m‚óŹ\u001b[39m Default subagents (code-reviewer, security-auditor, test-writer) \u001b[2m[\u001b[32mproject\u001b[39m]\u001b[22m\u001b[2m\u001b[22m            \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[33m‚óź\u001b[39m wshobson/agents (80 plugins ‚ÄĒ 2 pre-checked as defaults) \u001b[2m[\u001b[32mproject\u001b[39m]\u001b[22m\u001b[2m\u001b[33m  (13/65 agents)\u001b[39m\u001b[22m    \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[32m‚óŹ\u001b[39m cc-lens (local analytics dashboard) \u001b[2m[\u001b[33muser-doc\u001b[39m]\u001b[22m\u001b[2m\u001b[22m                                        \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[32m‚óŹ\u001b[39m agentshield (security audit CLI) \u001b[2m[\u001b[32mproject\u001b[39m]\u001b[22m\u001b[2m\u001b[22m                                            \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[32m‚óŹ\u001b[39m Pretty statusline (tokens, rate limits, diff stats) \u001b[2m[\u001b[32mproject\u001b[39m]\u001b[22m\u001b[2m\u001b[22m                         \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[32m‚óŹ\u001b[39m octo-issue-tracker (GitHub issues triage skill) \u001b[2m[\u001b[32mproject\u001b[39m]\u001b[22m\u001b[2m\u001b[22m                             \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[32m‚óŹ\u001b[39m octo-scenario-tester (scenarios-before-code discipline) \u001b[2m[\u001b[32mproject\u001b[39m]\u001b[22m\u001b[2m\u001b[22m                     \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[33m‚óź\u001b[39m Matt Pocock skills (21 skills ‚ÄĒ curated subset pre-checked) \u001b[2m[\u001b[32mproject\u001b[39m]\u001b[22m\u001b[2m\u001b[33m  (5/15 skills)\u001b[39m\u001b[22m  \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[32m‚óŹ\u001b[39m Agent Teams (research preview, swarms) ‚ö† experimental \u001b[2m[\u001b[32mproject\u001b[39m]\u001b[22m\u001b[2m\u001b[22m                       \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[2m‚ÄĘ\u001b[22m\u001b[2m STACK.md + .claude/stack.json (inventory)\u001b[22m                                             \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m\u001b[22m                                                                                          \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m\u001b[1mMCP servers:\u001b[22m\u001b[2m \u001b[2m(.mcp.json)\u001b[22m\u001b[2m\u001b[22m                                                                  \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[32m‚óŹ\u001b[39m GitHub \u001b[32m[creds set]\u001b[39m\u001b[22m                                                                    \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[32m‚óŹ\u001b[39m Context7\u001b[22m                                                                              \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m\u001b[22m                                                                                          \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m\u001b[1mCommand bundles:\u001b[22m\u001b[2m 10 selected \u001b[2m(22 commands total)\u001b[22m\u001b[2m\u001b[22m                                          \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[32m‚óŹ\u001b[39m Expo core extras \u001b[2m(5 cmds)\u001b[22m\u001b[2m\u001b[22m                                                             \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[32m‚óŹ\u001b[39m Expo + Stripe (React Native SDK) \u001b[2m(1 cmds)\u001b[22m\u001b[2m\u001b[22m                                             \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[32m‚óŹ\u001b[39m Expo + RevenueCat \u001b[2m(1 cmds)\u001b[22m\u001b[2m\u001b[22m                                                            \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[32m‚óŹ\u001b[39m Expo state (Zustand) \u001b[2m(1 cmds)\u001b[22m\u001b[2m\u001b[22m                                                         \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[32m‚óŹ\u001b[39m Expo forms (react-hook-form + zod) \u001b[2m(3 cmds)\u001b[22m\u001b[2m\u001b[22m                                           \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[32m‚óŹ\u001b[39m Expo icons (lucide + Expo vector) \u001b[2m(2 cmds)\u001b[22m\u001b[2m\u001b[22m                                            \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[32m‚óŹ\u001b[39m Better Auth on Expo \u001b[2m(4 cmds)\u001b[22m\u001b[2m\u001b[22m                                                          \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[32m‚óŹ\u001b[39m Zod validation \u001b[2m(1 cmds)\u001b[22m\u001b[2m\u001b[22m                                                               \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[32m‚óŹ\u001b[39m Biome (default formatter + linter, replaces Prettier+ESLint) \u001b[2m(2 cmds)\u001b[22m\u001b[2m\u001b[22m                 \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2m  \u001b[32m‚óŹ\u001b[39m Husky + lint-staged \u001b[2m(2 cmds)\u001b[22m\u001b[2m\u001b[22m                                                          \u001b[90m‚Ēā\u001b[39m\r\n\u001b[90m‚Ēā"]
