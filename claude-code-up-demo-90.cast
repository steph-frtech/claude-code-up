[49.502617, "o", "\u001b[0minit\u001b[0m\u001b[0m \u001b[0m\u001b[0m‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ‚ĒĀ\u001b[0m\u001b[0m\r\n\r\n\u001b[0m\u001b[0m  \u001b[0m\u001b[0m\u001b[1m\u001b[34m‚ĄĻ\u001b[0m\u001b[0m \u001b[0m\u001b[0m\u001b[34mWelcome to Biome! Let's get you started...\r\n\u001b[0m\u001b[0m  \u001b[0m\u001b[0m  \u001b[0m\u001b[0m\u001b[34m\r\n\u001b[0m\u001b[0m  \u001b[0m\u001b[0m  \u001b[0m\u001b[0m\u001b[1m\u001b[34mFiles created \u001b[0m\u001b[0m\u001b[34m\r\n\u001b[0m\u001b[0m  \u001b[0m\u001b[0m  \u001b[0m\u001b[0m\u001b[34m\r\n\u001b[0m\u001b[0m  \u001b[0m\u001b[0m  \u001b[0m\u001b[0m\u001b[34m  \u001b[0m\u001b[0m\u001b[2m\u001b[34m- \u001b[0m\u001b[0m\u001b[1m\u001b[34mbiome.json\u001b[0m\u001b[0m\u001b[34m\r\n\u001b[0m\u001b[0m  \u001b[0m\u001b[0m  \u001b[0m\u001b[0m\u001b[34m    Your project configuration. See \u001b[0m\u001b[0m\u001b[34m\u001b]8;;https://biomejs.dev/reference/configuration\u001b\\https://biomejs.dev/reference/configuration\u001b]8;;\u001b\\\u001b[0m\u001b[0m\u001b[34m\r\n\u001b[0m\u001b[0m  \u001b[0m\u001b[0m  \u001b[0m\u001b[0m\u001b[34m\r\n\u001b[0m\u001b[0m  \u001b[0m\u001b[0m  \u001b[0m\u001b[0m\u001b[34mFound an ignore file. Biome enabled \u001b[0m\u001b[0m\u001b[34m\u001b]8;;https://biomejs.dev/guides/integrate-in-vcs\u001b\\VCS integration.\u001b]8;;\u001b\\\u001b[0m\u001b[0m\u001b[1m\u001b[34m\r\n\u001b[0m\u001b[0m  \u001b[0m\u001b[0m  \u001b[0m\u001b[0m\u001b[1m\u001b[34m\r\n\u001b[0m\u001b[0m  \u001b[0m\u001b[0m  \u001b[0m\u001b[0m\u001b[1m\u001b[34mNext Steps \u001b[0m\u001b[0m\u001b[34m\r\n\u001b[0m\u001b[0m  \u001b[0m\u001b[0m  \u001b[0m\u001b[0m\u001b[34m\r\n\u001b[0m\u001b[0m  \u001b[0m\u001b[0m  \u001b[0m\u001b[0m\u001b[34m  \u001b[0m\u001b[0m\u001b[2m\u001b[34m1.\u001b[0m\u001b[0m\u001b[34m \u001b[0m\u001b[0m\u001b[1m\u001b[34mSetup an editor extension\u001b[0m\u001b[0m\u001b[34m\r\n\u001b[0m\u001b[0m  \u001b[0m\u001b[0m  \u001b[0m\u001b[0m\u001b[34m     Get live errors as you type and format when you save.\r\n\u001b[0m\u001b[0m  \u001b[0m\u001b[0m  \u001b[0m\u001b[0m\u001b[34m     Learn more at \u001b[0m\u001b[0m\u001b[34m\u001b]8;;https://biomejs.dev/guides/editors/first-party-extensions/\u001b\\https://biomejs.dev/guides/editors/first-party-extensions/\u001b]8;;\u001b\\\u001b[0m\u001b[0m\u001b[34m\r\n\u001b[0m\u001b[0m  \u001b[0m\u001b[0m  \u001b[0m\u001b[0m\u001b[34m\r\n\u001b[0m\u001b[0m  \u001b[0m\u001b[0m  \u001b[0m\u001b[0m\u001b[34m  \u001b[0m\u001b[0m\u001b[2m\u001b[34m2.\u001b[0m\u001b[0m\u001b[34m \u001b[0m\u001b[0m\u001b[1m\u001b[34mTry a command\u001b[0m\u001b[0m\u001b[34m\r\n\u001b[0m\u001b[0m  \u001b[0m\u001b[0m  \u001b[0m\u001b[0m\u001b[34m     \u001b[0m\u001b[0m\u001b[3m\u001b[34mbiome check\u001b[0m\u001b[0m\u001b[34m  checks formatting, import sorting, and lint rules.\r\n\u001b[0m\u001b[0m  \u001b[0m\u001b[0m  \u001b[0m\u001b[0m\u001b[34m     \u001b[0m\u001b[0m\u001b[3m\u001b[34mbiome --help\u001b[0m\u001b[0m\u001b[34m displays the available commands.\r\n\u001b[0m\u001b[0m  \u001b[0m\u001b[0m  \u001b[0m\u001b[0m\u001b[34m\r\n"]
[49.50273, "o", "\u001b[0m\u001b[0m  \u001b[0m\u001b[0m  \u001b[0m\u001b[0m\u001b[34m  \u001b[0m\u001b[0m\u001b[2m\u001b[34m3.\u001b[0m\u001b[0m\u001b[34m \u001b[0m\u001b[0m\u001b[1m\u001b[34mMigrate from ESLint and Prettier\u001b[0m\u001b[0m\u001b[34m\r\n\u001b[0m\u001b[0m  \u001b[0m\u001b[0m  \u001b[0m\u001b[0m\u001b[34m     \u001b[0m\u001b[0m\u001b[3m\u001b[34mbiome migrate eslint\u001b[0m\u001b[0m\u001b[34m   migrates your ESLint configuration to Biome.\r\n\u001b[0m\u001b[0m  \u001b[0m\u001b[0m  \u001b[0m\u001b[0m\u001b[34m     \u001b[0m\u001b[0m\u001b[3m\u001b[34mbiome migrate prettier\u001b[0m\u001b[0m\u001b[34m migrates your Prettier configuration to Biome.\r\n\u001b[0m\u001b[0m  \u001b[0m\u001b[0m  \u001b[0m\u001b[0m\u001b[34m\r\n\u001b[0m\u001b[0m  \u001b[0m\u001b[0m  \u001b[0m\u001b[0m\u001b[34m  \u001b[0m\u001b[0m\u001b[2m\u001b[34m4.\u001b[0m\u001b[0m\u001b[34m \u001b[0m\u001b[0m\u001b[1m\u001b[34mRead the documentation\u001b[0m\u001b[0m\u001b[34m\r\n\u001b[0m\u001b[0m  \u001b[0m\u001b[0m  \u001b[0m\u001b[0m\u001b[34m     Find guides and documentation at \u001b[0m\u001b[0m\u001b[34m\u001b]8;;https://biomejs.dev/guides/getting-started/\u001b\\https://biomejs.dev/guides/getting-started/\u001b]8;;\u001b\\\u001b[0m\u001b[0m\u001b[34m\r\n\u001b[0m\u001b[0m  \u001b[0m\u001b[0m  \u001b[0m\u001b[0m\u001b[34m\r\n\u001b[0m\u001b[0m  \u001b[0m\u001b[0m  \u001b[0m\u001b[0m\u001b[34m  \u001b[0m\u001b[0m\u001b[2m\u001b[34m5.\u001b[0m\u001b[0m\u001b[34m \u001b[0m\u001b[0m\u001b[1m\u001b[34mGet involved with the community\u001b[0m\u001b[0m\u001b[34m\r\n\u001b[0m\u001b[0m  \u001b[0m\u001b[0m  \u001b[0m\u001b[0m\u001b[34m     Ask questions and contribute on GitHub: \u001b[0m\u001b[0m\u001b[34m\u001b]8;;https://github.com/biomejs/biome\u001b\\https://github.com/biomejs/biome\u001b]8;;\u001b\\\u001b[0m\u001b[0m\u001b[34m\r\n\u001b[0m\u001b[0m  \u001b[0m\u001b[0m  \u001b[0m\u001b[0m\u001b[34m     Seek for help on Discord: \u001b[0m\u001b[0m\u001b[34m\u001b]8;;https://biomejs.dev/chat\u001b\\https://biomejs.dev/chat\u001b]8;;\u001b\\\u001b[0m\u001b[0m\u001b[34m\r\n\u001b[0m\u001b[0m  \u001b[0m\u001b[0m\r\n\u001b[0m\u001b[0m  \u001b[0m\u001b[0m\r\n\u001b[0m\r\n"]
