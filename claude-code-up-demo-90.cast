[9.528336, "o", "\u001b[?25l\u001b[90m‚Ēā\u001b[39m\r\n\u001b[36m‚óÜ\u001b[39m  Database(s)?\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[36m‚óĽ\u001b[39m PostgreSQL (self-hosted)\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[2m‚óĽ\u001b[22m \u001b[2mMySQL / MariaDB\u001b[22m\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[2m‚óĽ\u001b[22m \u001b[2mSQLite\u001b[22m\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[2m‚óĽ\u001b[22m \u001b[2mMongoDB\u001b[22m\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[2m‚óĽ\u001b[22m \u001b[2mRedis (cache / queue)\u001b[22m\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[2m‚óĽ\u001b[22m \u001b[2mSupabase (managed Postgres + auth)\u001b[22m\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[2m‚óĽ\u001b[22m \u001b[2mPlanetScale (managed MySQL)\u001b[22m\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[2m‚óĽ\u001b[22m \u001b[2mNeon (serverless Postgres)\u001b[22m\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[2m‚óĽ\u001b[22m \u001b[2mElasticsearch / OpenSearch\u001b[22m\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[2m‚óĽ\u001b[22m \u001b[2mVector DB (pgvector / Qdrant / Pinecone)\u001b[22m\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[2m‚óĽ\u001b[22m \u001b[2mNo database\u001b[22m\r\n\u001b[36m‚ĒĒ\u001b[39m\r\n"]
[9.797148, "o", "\u001b[999D\u001b[14A\u001b[2B\u001b[J\u001b[36m‚Ēā\u001b[39m  \u001b[2m‚óĽ\u001b[22m \u001b[2mPostgreSQL (self-hosted)\u001b[22m\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[2m‚óĽ\u001b[22m \u001b[2mMySQL / MariaDB\u001b[22m\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[2m‚óĽ\u001b[22m \u001b[2mSQLite\u001b[22m\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[2m‚óĽ\u001b[22m \u001b[2mMongoDB\u001b[22m\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[2m‚óĽ\u001b[22m \u001b[2mRedis (cache / queue)\u001b[22m\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[2m‚óĽ\u001b[22m \u001b[2mSupabase (managed Postgres + auth)\u001b[22m\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[2m‚óĽ\u001b[22m \u001b[2mPlanetScale (managed MySQL)\u001b[22m\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[2m‚óĽ\u001b[22m \u001b[2mNeon (serverless Postgres)\u001b[22m\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[2m‚óĽ\u001b[22m \u001b[2mElasticsearch / OpenSearch\u001b[22m\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[2m‚óĽ\u001b[22m \u001b[2mVector DB (pgvector / Qdrant / Pinecone)\u001b[22m\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[36m‚óĽ\u001b[39m No database\r\n\u001b[36m‚ĒĒ\u001b[39m\r\n"]
