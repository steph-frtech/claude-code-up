[27.27785, "o", "\u001b[1m‚úÖ Your project is ready!\u001b[22m\r\n"]
[27.277896, "o", "\r\n"]
[27.277922, "o", "To run your project, navigate to the directory and run one of the following npm commands.\r\n"]
