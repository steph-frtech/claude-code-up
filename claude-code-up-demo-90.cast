[14.676524, "o", "\u001b[?25l\u001b[90m‚Ēā\u001b[39m\r\n\u001b[36m‚óÜ\u001b[39m  Run init commands for your stack? (space to toggle, enter to confirm)\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[32m‚óľ\u001b[39m Expo core extras \u001b[2m(5 cmds)\u001b[22m \u001b[33m[expo]\u001b[39m \u001b[2m(Router, constants, splash, status bar ‚ÄĒ the basics every Expo app needs)\u001b[22m\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[32m‚óľ\u001b[39m \u001b[2mExpo + Stripe (React Native SDK) \u001b[2m(1 cmd)\u001b[22m\u001b[2m \u001b[33m[expo]\u001b[39m\u001b[22m \u001b[2m(Stripe React Native payments SDK)\u001b[22m\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[32m‚óľ\u001b[39m \u001b[2mExpo + RevenueCat \u001b[2m(1 cmd)\u001b[22m\u001b[2m \u001b[33m[Mobile + expo]\u001b[39m\u001b[22m \u001b[2m(react-native-purchases for IAP & subscriptions)\u001b[22m\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[32m‚óľ\u001b[39m \u001b[2mExpo state (Zustand) \u001b[2m(1 cmd)\u001b[22m\u001b[2m \u001b[33m[expo]\u001b[39m\u001b[22m \u001b[2m(Zustand client-side state)\u001b[22m\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[32m‚óľ\u001b[39m \u001b[2mExpo forms (react-hook-form + zod) \u001b[2m(3 cmds)\u001b[22m\u001b[2m \u001b[33m[expo]\u001b[39m\u001b[22m \u001b[2m(Schema-validated forms)\u001b[22m\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[32m‚óľ\u001b[39m \u001b[2mExpo icons (lucide + Expo vector) \u001b[2m(2 cmds)\u001b[22m\u001b[2m \u001b[33m[expo]\u001b[39m\u001b[22m \u001b[2m(Icon libraries)\u001b[22m\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[32m‚óľ\u001b[39m \u001b[2mBetter Auth on Expo \u001b[2m(4 cmds)\u001b[22m\u001b[2m \u001b[33m[TS + expo]\u001b[39m\u001b[22m \u001b[2m(Better Auth Expo plugin + Expo auth-session for OAuth)\u001b[22m\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[32m‚óľ\u001b[39m \u001b[2mZod validation \u001b[2m(1 cmd)\u001b[22m\u001b[2m \u001b[33m[Backend + Fullstack + Web + Mobile + TS]\u001b[39m\u001b[22m \u001b[2m(Schema validation)\u001b[22m\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[2m‚óĽ\u001b[22m \u001b[2mPrettier + ESLint (TS) ‚ÄĒ legacy \u001b[2m(1 cmd)\u001b[22m\u001b[2m \u001b[33m[Opt-in]\u001b[39m\u001b[22m\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[32m‚óľ\u001b[39m \u001b[2mBiome (default formatter + linter, replaces Prettier+ESLint) \u001b[2m(2 cmds)\u001b[22m\u001b[2m \u001b[33m[TS]\u001b[39m\u001b[22m \u001b[2m(Single Rust-based formatter+linter.\u001b[22m\r\n\u001b[2mFaster, single config, drop-in for most projects.)\u001b[22m\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[32m‚óľ\u001b[39m \u001b[2mHusky + lint-staged \u001b[2m(2 cmds)\u001b[22m\u001b[2m \u001b[33m[TS]\u001b[39m\u001b[22m \u001b[2m(Pre-commit hooks)\u001b[22m\r\n\u001b[36m‚ĒĒ\u001b[39m\r\n"]
[15.196246, "o", "\u001b[999D\u001b[15A\u001b[1B"]
[15.196267, "o", "\u001b[J\u001b[32m‚óá\u001b[39m  Run init commands for your stack? (space to toggle, enter to confirm)\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2mExpo core extras \u001b[2m(5 cmds)\u001b[22m\u001b[2m \u001b[33m[expo]\u001b[39m\u001b[22m\u001b[2m, \u001b[22m\u001b[2mExpo + Stripe (React Native SDK) \u001b[2m(1 cmd)\u001b[22m\u001b[2m \u001b[33m[expo]\u001b[39m\u001b[22m\u001b[2m, \u001b[22m\u001b[2mExpo + RevenueCat \u001b[2m(1 cmd)\u001b[22m\u001b[2m \u001b[33m[Mobile\u001b[39m\r\n\u001b[33m+ expo]\u001b[39m\u001b[22m\u001b[2m, \u001b[22m\u001b[2mExpo state (Zustand) \u001b[2m(1 cmd)\u001b[22m\u001b[2m \u001b[33m[expo]\u001b[39m\u001b[22m\u001b[2m, \u001b[22m\u001b[2mExpo forms (react-hook-form + zod) \u001b[2m(3 cmds)\u001b[22m\u001b[2m \u001b[33m[expo]\u001b[39m\u001b[22m\u001b[2m, \u001b[22m\u001b[2mExpo icons (lucide +\u001b[22m\r\n\u001b[2mExpo vector) \u001b[2m(2 cmds)\u001b[22m\u001b[2m \u001b[33m[expo]\u001b[39m\u001b[22m\u001b[2m, \u001b[22m\u001b[2mBetter Auth on Expo \u001b[2m(4 cmds)\u001b[22m\u001b[2m \u001b[33m[TS + expo]\u001b[39m\u001b[22m\u001b[2m, \u001b[22m\u001b[2mZod validation \u001b[2m(1 cmd)\u001b[22m\u001b[2m \u001b[33m[Backend + Fullstack +\u001b[39m\r\n\u001b[33mWeb + Mobile + TS]\u001b[39m\u001b[22m\u001b[2m, \u001b[22m\u001b[2mBiome (default formatter + linter, replaces Prettier+ESLint) \u001b[2m(2 cmds)\u001b[22m\u001b[2m \u001b[33m[TS]\u001b[39m\u001b[22m\u001b[2m, \u001b[22m\u001b[2mHusky + lint-staged \u001b[2m(2\u001b[22m\r\n\u001b[2mcmds)\u001b[22m\u001b[2m \u001b[33m[TS]\u001b[39m\u001b[22m"]
