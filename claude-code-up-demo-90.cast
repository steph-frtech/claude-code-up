[10.010411, "o", "\u001b[?25l\u001b[90m‚Ēā\u001b[39m\r\n\u001b[36m‚óÜ\u001b[39m  Scaffold a starter app for expo in this directory?\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[32m‚óŹ\u001b[39m Expo (create-expo-app)  \u001b[2m(npx -y create-expo-app@latest {{name}})\u001b[22m \u001b[2m(Bootstrap React Native app via Expo)\u001b[22m\r\n\u001b[36m‚Ēā\u001b[39m  \u001b[2m‚óč\u001b[22m \u001b[2mSkip ‚ÄĒ don't scaffold (just claude-code-up config)\u001b[22m\r\n\u001b[36m‚ĒĒ\u001b[39m\r\n"]
[10.448157, "o", "\u001b[999D\u001b[5A\u001b[1B\u001b[J\u001b[32m‚óá\u001b[39m  Scaffold a starter app for expo in this directory?\r\n\u001b[90m‚Ēā\u001b[39m  \u001b[2mExpo (create-expo-app)  \u001b[2m(npx -y create-expo-app@latest {{name}})\u001b[22m\u001b[2m\u001b[22m"]
