{
  "schemaVersion": "1",
  "scaffolders": [
    {
      "id": "expo",
      "name": "Expo (create-expo-app)",
      "description": "Bootstrap React Native app via Expo",
      "command": "npx",
      "args": ["-y", "create-expo-app@latest", "{{name}}"],
      "matchFrameworks": ["expo", "rn"],
      "templates": [
        {
          "id": "default",
          "name": "Default — Tabs + expo-router + TypeScript",
          "description": "Recommended starter. File-based routing with bottom tabs, TS by default.",
          "extraArgs": [],
          "default": true
        },
        {
          "id": "blank",
          "name": "Blank — minimal (JavaScript)",
          "description": "Empty React Native app, no router, plain JS.",
          "extraArgs": ["--template", "blank"]
        },
        {
          "id": "blank-typescript",
          "name": "Blank — minimal (TypeScript)",
          "description": "Empty React Native app, no router, TS.",
          "extraArgs": ["--template", "blank-typescript"]
        },
        {
          "id": "tabs",
          "name": "Tabs (legacy)",
          "description": "Older bottom-tabs starter. Prefer `default` unless you specifically want this layout.",
          "extraArgs": ["--template", "tabs"]
        },
        {
          "id": "bare-minimum",
          "name": "Bare workflow — no Expo modules",
          "description": "Vanilla React Native baseline. Use when you need native code control.",
          "extraArgs": ["--template", "bare-minimum"]
        }
      ]
    },
    {
      "id": "nextjs",
      "name": "Next.js (create-next-app)",
      "description": "Bootstrap Next.js with App Router + TypeScript + Tailwind",
      "command": "npx",
      "args": [
        "-y",
        "create-next-app@latest",
        "{{name}}",
        "--typescript",
        "--app",
        "--tailwind",
        "--eslint",
        "--use-npm"
      ],
      "matchFrameworks": ["nextjs", "nextjs-js"]
    },
    {
      "id": "vite-react",
      "name": "Vite + React (TypeScript)",
      "description": "Vite + React + TS scaffold",
      "command": "npm",
      "args": ["create", "vite@latest", "{{name}}", "--", "--template", "react-ts"],
      "matchFrameworks": ["react-vite"]
    },
    {
      "id": "vue",
      "name": "Vue 3 (create-vue)",
      "description": "Interactive Vue 3 scaffolder",
      "command": "npm",
      "args": ["create", "vue@latest", "{{name}}"],
      "matchFrameworks": ["vue"]
    },
    {
      "id": "svelte",
      "name": "SvelteKit (create-svelte)",
      "description": "Interactive SvelteKit scaffolder",
      "command": "npm",
      "args": ["create", "svelte@latest", "{{name}}"],
      "matchFrameworks": ["svelte"]
    },
    {
      "id": "remix",
      "name": "Remix (create-remix)",
      "description": "Remix app scaffold",
      "command": "npx",
      "args": ["-y", "create-remix@latest", "{{name}}"],
      "matchFrameworks": ["remix"]
    },
    {
      "id": "astro",
      "name": "Astro (create-astro)",
      "description": "Interactive Astro scaffolder",
      "command": "npm",
      "args": ["create", "astro@latest", "{{name}}"],
      "matchFrameworks": ["astro"]
    },
    {
      "id": "nestjs",
      "name": "NestJS (nest CLI)",
      "description": "Bootstrap a NestJS API (TypeScript)",
      "command": "npx",
      "args": ["-y", "@nestjs/cli", "new", "{{name}}"],
      "matchFrameworks": ["nestjs"]
    },
    {
      "id": "fastapi",
      "name": "FastAPI starter (uv)",
      "description": "Requires uv installed — sets up a FastAPI project",
      "command": "uvx",
      "args": ["--from", "fastapi[standard]", "fastapi", "dev"],
      "matchFrameworks": ["fastapi"]
    }
  ]
}
